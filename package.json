{
  "name": "generative-ui-playground",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "$npm_execpath run build && vite preview",
    "deploy": "$npm_execpath run build && wrangler deploy",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings",
    "db:migrate:local": "wrangler d1 migrations apply DB --local",
    "db:migrate:remote": "wrangler d1 migrations apply DB --remote",
    "format": "prettier --check \"src/**/*.{ts,tsx,css}\" \"*.{ts,json,jsonc,md}\"",
    "format:fix": "prettier --write \"src/**/*.{ts,tsx,css}\" \"*.{ts,json,jsonc,md}\""
  },
  "dependencies": {
    "@ai-sdk/react": "^3.0.195",
    "@cloudflare/ai-chat": "^0.7.2",
    "@cloudflare/codemode": "^0.3.8",
    "agents": "^0.13.3",
    "ai": "^6.0.193",
    "hono": "^4.12.23",
    "hono-agents": "^3.0.11",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "workers-ai-provider": "^3.1.14",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.2.3",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "prettier": "^3.8.3",
    "vite": "^8.0.14",
    "wrangler": "^4.17.0"
  }
}
